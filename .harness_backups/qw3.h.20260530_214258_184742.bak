#ifndef QW3_H
#define QW3_H

#include <stdbool.h>
#include <stddef.h>
#include <stdint.h>
#include <stdio.h>

/* Public engine boundary.
 *
 * qw3.c is a minimalist, single-model inference engine for Qwen3.6-35B-A3B,
 * following the ds4.c philosophy: one model, zero frameworks, vertical code.
 *
 * The architecture is a hybrid Gated-DeltaNet / GQA transformer with sparse
 * MoE (256 experts, top-8 routing + 1 shared expert).  30 of the 40 layers
 * use linear attention (Gated DeltaNet with a fixed-size recurrent state),
 * while 10 layers use standard GQA with a traditional KV cache.
 *
 * Callers treat qw3_engine as the loaded model and qw3_session as one mutable
 * inference timeline.  A session owns the live KV cache (for GQA layers),
 * the DeltaNet recurrent state (for linear layers), and logits. */

typedef enum {
    QW3_BACKEND_METAL,
    QW3_BACKEND_CPU,
} qw3_backend;

typedef enum {
    QW3_THINK_NONE,
        QW3_THINK_ON,
        QW3_THINK_HIGH,
        QW3_THINK_ON,
} qw3_think_mode;

/* Default sampling parameters. */
#define QW3_DEFAULT_TOP_P 1.0f
#define QW3_DEFAULT_MIN_P 0.05f

/* Downgrade THINK_HIGH to THINK_ON or THINK_NONE based on context size. */
qw3_think_mode qw3_think_mode_for_context(qw3_think_mode mode, int ctx_size);

typedef enum {
    QW3_LOG_DEFAULT,
    QW3_LOG_PREFILL,
    QW3_LOG_GENERATION,
    QW3_LOG_KVCACHE,
    QW3_LOG_TOOL,
    QW3_LOG_WARNING,
    QW3_LOG_TIMING,
    QW3_LOG_OK,
    QW3_LOG_ERROR,
} qw3_log_type;

typedef struct {
    int *v;
    int len;
    int cap;
} qw3_tokens;

typedef struct {
    int id;
    float logit;
    float logprob;
} qw3_token_score;

typedef struct qw3_engine qw3_engine;
typedef struct qw3_session qw3_session;

typedef void (*qw3_session_progress_fn)(void *ud, const char *event,
                                        int current, int total);

typedef struct {
    const char *model_path;
    qw3_backend backend;
    int n_threads;
    bool warm_weights;
} qw3_engine_options;

typedef void (*qw3_token_emit_fn)(void *ud, int token);
typedef void (*qw3_generation_done_fn)(void *ud);

typedef struct {
    uint64_t total_bytes;
    uint64_t gqa_kv_bytes;       /* KV cache for the 10 full-attention layers */
    uint64_t deltanet_state_bytes; /* recurrent state for the 30 linear layers */
    uint64_t scratch_bytes;
} qw3_context_memory;

/* Engine lifecycle. */
int qw3_engine_open(qw3_engine **out, const qw3_engine_options *opt);
void qw3_engine_close(qw3_engine *e);
void qw3_engine_summary(qw3_engine *e);
void qw3_engine_inspect(qw3_engine *e, FILE *fp);
void qw3_engine_layer_types(qw3_engine *e, int layer, FILE *fp);
void qw3_engine_probe_token(qw3_engine *e, int token, FILE *fp);
